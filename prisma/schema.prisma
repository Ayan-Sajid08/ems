generator client {
  provider = "prisma-client-js"
  url      = env("DATABASE_URL")
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  passwordHash  String
  role          UserRole
  employee      Employee?
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

model Department {
  id            String      @id @default(cuid())
  name          String      @unique
  employees     Employee[]
}

model Employee {
  id            String      @id @default(cuid())
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id])
  firstName     String
  lastName      String
  phone         String      @unique
  departmentId  String?
  department    Department?  @relation(fields: [departmentId], references: [id])
  baseSalary    Decimal?
  attendances   Attendance[]
  leaves        Leave[]
  payslips      Payslip[]
}

model Attendance {
  id            String      @id @default(cuid())
  employeeId    String
  employee      Employee    @relation(fields: [employeeId], references: [id])
  clockInAt     DateTime
  clockOutAt    DateTime?
}

model Leave {
  id            String      @id @default(cuid())
  employeeId    String
  employee      Employee    @relation(fields: [employeeId], references: [id])
  start         DateTime
  end           DateTime
  reason        String
  status        LeaveStatus @default(PENDING)
}

enum LeaveStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Payslip {
  id            String      @id @default(cuid())
  employeeId    String
  employee      Employee    @relation(fields: [employeeId], references: [id])
  baseSalary    Decimal
  bonus         Decimal?
  deductions    Decimal?
  month         Int
  year          Int
}